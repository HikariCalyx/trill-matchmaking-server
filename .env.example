# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# TURN Configuration
# This server assumes coturn runs on the SAME instance.
#
# TURN_ADDR is the address advertised to clients (e.g. turn.example.com:3478).
TURN_ADDR=turn.example.com:3478

# --- Dynamic credentials (default) ---
# When USE_STATIC_TURN_CREDENTIAL is false/unset, the server generates a random,
# time-limited TURN credential (valid for TURN_CREDENTIAL_TTL seconds) using
# coturn's REST API mechanism. This requires coturn to be configured with:
#   use-auth-secret
#   static-auth-secret=<the same value as TURN_SECRET>
TURN_SECRET=your-coturn-static-auth-secret
# Credential lifetime in seconds (default: 3600 = 1 hour)
TURN_CREDENTIAL_TTL=3600

# --- Static credentials ---
# Set USE_STATIC_TURN_CREDENTIAL=true to advertise fixed credentials instead.
# In that case TURN_USER and TURN_CREDENTIAL are used together with TURN_ADDR.
# USE_STATIC_TURN_CREDENTIAL=true
# TURN_USER=user
# TURN_CREDENTIAL=password

# Logging
DEBUG=false
LOG_LEVEL=INFO
